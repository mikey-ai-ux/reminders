@page "/login"
@inject NavigationManager Navigation

<PageTitle>Sign In — Reminders</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon">🔐</div>
            <h1>Welcome back</h1>
            <p>Sign in to your Reminders account</p>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-error">@Error</div>
        }

        <form method="post" action="/login-local">
            <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? "/reminders")" />

            <div class="form-group">
                <label for="email">Email</label>
                <input id="email" name="email" class="form-input" type="email" placeholder="you@example.com" required />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="password-row">
                    <input id="password" name="password" class="form-input" type="password" placeholder="••••••••" required />
                    <button type="button" class="btn btn-ghost btn-sm" onclick="toggleLoginPassword()">Show</button>
                </div>
            </div>

            <div class="form-check">
                <input id="remember" name="rememberMe" type="checkbox" value="true" />
                <label for="remember">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Sign In</button>
        </form>

        <div class="divider"><span>or continue with</span></div>

        <div class="social-buttons">
            <a href="/challenge/Google?returnUrl=/" class="btn btn-social">Google</a>
            <a href="/challenge/Apple?returnUrl=/" class="btn btn-social">Apple</a>
        </div>

        <p class="auth-footer">Don't have an account? <a href="/register">Sign up free</a></p>
    </div>
</div>

<script>
function toggleLoginPassword(){
  const input = document.getElementById('password');
  if(!input) return;
  input.type = input.type === 'password' ? 'text' : 'password';
}
</script>

<style>
.password-row { display:flex; gap:.5rem; align-items:center; }
.password-row .form-input { flex:1; }
</style>

@code {
    [Parameter, SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
