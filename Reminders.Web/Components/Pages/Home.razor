@page "/"
<PageTitle>Reminders — Never Forget Anything</PageTitle>

<div class="hero-section">
    <div class="hero-content">
        <div class="hero-badge">✨ Free to get started</div>
        <h1 class="hero-title">Never miss a thing<br /><span class="gradient-text">with smart reminders</span></h1>
        <p class="hero-subtitle">Schedule reminders via Email, Push, SMS, or Voice. Get notified exactly when you need it, in your timezone.</p>
        <div class="hero-actions">
            <AuthorizeView>
                <Authorized>
                    <a href="/reminders" class="btn btn-primary btn-lg">🔔 My Reminders</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/register" class="btn btn-primary btn-lg">Get Started Free</a>
                    <a href="/login" class="btn btn-secondary btn-lg">Sign In</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
    <div class="hero-visual">
        <div class="hero-card">
            <div class="reminder-preview">
                <div class="rp-icon">🔔</div>
                <div class="rp-content">
                    <div class="rp-name">Team standup</div>
                    <div class="rp-time">Today, 9:00 AM PST</div>
                </div>
                <div class="rp-badge active">Active</div>
            </div>
            <div class="reminder-preview">
                <div class="rp-icon">💊</div>
                <div class="rp-content">
                    <div class="rp-name">Take medication</div>
                    <div class="rp-time">Daily, 8:00 PM</div>
                </div>
                <div class="rp-badge active">Active</div>
            </div>
            <div class="reminder-preview">
                <div class="rp-icon">📅</div>
                <div class="rp-content">
                    <div class="rp-name">Pay rent</div>
                    <div class="rp-time">Monthly, 1st</div>
                </div>
                <div class="rp-badge paused">Paused</div>
            </div>
        </div>
    </div>
</div>

<div class="features-section">
    <h2 class="section-title">Everything you need to stay on track</h2>
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon">📧</div>
            <h3>Email Reminders</h3>
            <p>Get timely email notifications for your most important reminders. Available on Free plan.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🔔</div>
            <h3>Push Notifications</h3>
            <p>Instant browser push notifications — works even when the app is closed. Free plan included.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">📱</div>
            <h3>SMS & Voice</h3>
            <p>Critical reminders delivered by text or phone call. Available on Pro plan.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🌍</div>
            <h3>Timezone Aware</h3>
            <p>All reminders fire at the right time, no matter where you are in the world.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🔁</div>
            <h3>Recurring Schedules</h3>
            <p>Daily, weekly, or monthly — set it once and forget about setting it again.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">⏸️</div>
            <h3>Pause & Resume</h3>
            <p>Going on vacation? Pause any reminder and resume it when you're back.</p>
        </div>
    </div>
</div>

<div class="pricing-section">
    <h2 class="section-title">Simple, transparent pricing</h2>
    <div class="pricing-grid">
        <div class="pricing-card">
            <div class="plan-name">Free</div>
            <div class="plan-price">$0 <span class="plan-period">/ month</span></div>
            <ul class="plan-features">
                <li>✅ Up to 10 reminders</li>
                <li>✅ Email notifications</li>
                <li>✅ Push notifications</li>
                <li>✅ Recurring schedules</li>
                <li>❌ SMS notifications</li>
                <li>❌ Voice calls</li>
            </ul>
            <AuthorizeView>
                <NotAuthorized>
                    <a href="/register" class="btn btn-secondary btn-full">Get Started Free</a>
                </NotAuthorized>
                <Authorized>
                    <a href="/reminders" class="btn btn-secondary btn-full">Go to Reminders</a>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="pricing-card featured">
            <div class="plan-badge">Most Popular</div>
            <div class="plan-name">Pro</div>
            <div class="plan-price">$9.99 <span class="plan-period">/ month</span></div>
            <ul class="plan-features">
                <li>✅ Unlimited reminders</li>
                <li>✅ Email notifications</li>
                <li>✅ Push notifications</li>
                <li>✅ Recurring schedules</li>
                <li>✅ SMS notifications</li>
                <li>✅ Voice call reminders</li>
            </ul>
            <AuthorizeView>
                <NotAuthorized>
                    <a href="/register" class="btn btn-primary btn-full">Start Free Trial</a>
                </NotAuthorized>
                <Authorized>
                    <a href="/profile/subscription" class="btn btn-primary btn-full">Upgrade to Pro</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<style>
.hero-section { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; padding: 5rem 0 4rem; }
.hero-badge { display: inline-block; background: var(--color-primary-alpha); color: var(--color-primary); padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; }
.hero-title { font-size: 3rem; font-weight: 800; line-height: 1.15; margin: 0 0 1.25rem; color: var(--color-text); }
.gradient-text { background: linear-gradient(135deg, var(--color-primary), #7b5ea7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-subtitle { font-size: 1.125rem; color: var(--color-text-muted); margin-bottom: 2rem; line-height: 1.6; }
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.hero-visual { display: flex; justify-content: center; }
.hero-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; padding: 1.5rem; width: 320px; display: flex; flex-direction: column; gap: 1rem; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
.reminder-preview { display: flex; align-items: center; gap: 1rem; padding: 0.75rem; background: var(--color-bg); border-radius: 10px; }
.rp-icon { font-size: 1.5rem; }
.rp-content { flex: 1; }
.rp-name { font-weight: 600; font-size: 0.9rem; color: var(--color-text); }
.rp-time { font-size: 0.775rem; color: var(--color-text-muted); margin-top: 2px; }
.rp-badge { font-size: 0.7rem; font-weight: 600; padding: 2px 8px; border-radius: 20px; }
.rp-badge.active { background: rgba(34,197,94,0.15); color: #22c55e; }
.rp-badge.paused { background: rgba(234,179,8,0.15); color: #eab308; }
.features-section { padding: 4rem 0; }
.section-title { text-align: center; font-size: 2rem; font-weight: 700; margin-bottom: 2.5rem; color: var(--color-text); }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.feature-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.75rem; }
.feature-icon { font-size: 2rem; margin-bottom: 1rem; }
.feature-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--color-text); }
.feature-card p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; line-height: 1.6; }
.pricing-section { padding: 4rem 0 5rem; }
.pricing-grid { display: grid; grid-template-columns: repeat(2, 400px); gap: 2rem; justify-content: center; }
.pricing-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem; position: relative; }
.pricing-card.featured { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
.plan-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: #fff; padding: 0.25rem 1rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; white-space: nowrap; }
.plan-name { font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem; }
.plan-price { font-size: 2.25rem; font-weight: 800; color: var(--color-text); margin-bottom: 1.5rem; }
.plan-period { font-size: 1rem; font-weight: 400; color: var(--color-text-muted); }
.plan-features { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
.plan-features li { font-size: 0.9rem; color: var(--color-text-muted); }
.btn-full { width: 100%; }
@@media (max-width: 900px) {
    .hero-section { grid-template-columns: 1fr; padding: 3rem 0 2rem; }
    .hero-title { font-size: 2rem; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
    .hero-visual { display: none; }
}
</style>

