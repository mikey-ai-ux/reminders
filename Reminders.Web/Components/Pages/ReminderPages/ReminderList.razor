@page "/reminders"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject IReminderService ReminderSvc
@inject UserManager<AppUser> UserManager
@inject ISubscriptionService SubSvc
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>My Reminders</PageTitle>

<div class="page-header">
    <div>
        <h1>🔔 My Reminders</h1>
        <p class="page-subtitle">Manage your scheduled reminders</p>

        @if (currentUser?.SubscriptionTier == SubscriptionTier.Free)
        {
            <div class="usage-row">
                <span class="badge badge-free">Free plan</span>
                <span class="usage-text">@totalCount / 10 reminders used</span>
                @if (totalCount >= 10)
                {
                    <span class="usage-limit">Limit reached</span>
                }
            </div>
            <div class="slot-bar" aria-label="Reminder slots usage">
                @for (var i = 1; i <= 10; i++)
                {
                    var cls = i <= totalCount
                        ? (i >= 10 ? "filled danger" : i >= 8 ? "filled warning" : "filled")
                        : string.Empty;
                    <span class="slot @cls"></span>
                }
            </div>
        }
    </div>
    <button class="btn btn-primary" @onclick="ShowNewForm" disabled="@(currentUser?.SubscriptionTier == SubscriptionTier.Free && totalCount >= 10)">+ New Reminder</button>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="HideForm">
        <div class="modal-card" @onclick:stopPropagation>
            <ReminderForm Reminder="editingReminder" CurrentUser="currentUser" OnSaved="OnReminderSaved" OnCancel="HideForm" />
        </div>
    </div>
}

@if (showForm || showDeleteConfirm)
{
    <style>
        body { overflow: hidden !important; }
    </style>
}

@if (showDeleteConfirm && pendingDeleteReminder is not null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="confirm-card" @onclick:stopPropagation>
            <h3>Delete reminder?</h3>
            <p>
                This will delete <strong>@pendingDeleteReminder.Name</strong> and cannot be undone.
            </p>
            <div class="confirm-actions">
                <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>Loading reminders...</p>
    </div>
}
else if (reminders.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <h2>No reminders yet</h2>
        <p>Create your first reminder to get started!</p>
        <button class="btn btn-primary" @onclick="ShowNewForm">+ New Reminder</button>
    </div>
}
else
{
    <div class="reminders-grid">
        @foreach (var reminder in reminders)
        {
            <ReminderCard Reminder="reminder"
                          CurrentUser="currentUser"
                          OnEdit="EditReminder"
                          OnPause="PauseReminder"
                          OnResume="ResumeReminder"
                          OnDelete="DeleteReminder" />
        }
    </div>
}

<style>
.page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.page-header h1 { font-size: 1.75rem; font-weight: 700; margin: 0 0 0.25rem; color: var(--color-text); }
.page-subtitle { color: var(--color-text-muted); margin: 0; font-size: 0.9rem; }
.usage-row { margin-top: .6rem; display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; }
.usage-text { font-size:.82rem; color: var(--color-text-muted); }
.usage-limit { font-size:.75rem; color:#fff; background:var(--color-danger); padding:2px 8px; border-radius:12px; }
.slot-bar { margin-top:.45rem; display:grid; grid-template-columns:repeat(10, minmax(16px, 1fr)); gap:.28rem; max-width:260px; }
.slot { height:8px; border-radius:999px; background:var(--color-border); }
.slot.filled { background:var(--color-primary); }
.slot.filled.warning { background: var(--color-warning); }
.slot.filled.danger { background: var(--color-danger); }

.reminders-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
.empty-state { text-align: center; padding: 5rem 1rem; }
.empty-icon { font-size: 4rem; margin-bottom: 1rem; }
.empty-state h2 { font-size: 1.5rem; color: var(--color-text); margin-bottom: 0.5rem; }
.empty-state p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
.loading-state { text-align: center; padding: 4rem; color: var(--color-text-muted); }
.spinner { width: 36px; height: 36px; border: 3px solid var(--color-border); border-top-color: var(--color-primary); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@@keyframes spin { to { transform: rotate(360deg); } }

.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; z-index: 500; padding: 1rem; overscroll-behavior: contain; }
.modal-card { background: var(--color-surface); border-radius: 16px; padding: 2rem; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; }
.confirm-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 14px; width:100%; max-width: 430px; padding: 1.2rem 1.2rem 1rem; box-shadow: var(--shadow-lg); }
@@media (max-width: 768px) {
  .modal-overlay { padding: 0; align-items: stretch; }
  .modal-card { border-radius: 0; max-width: none; max-height: none; height: 100dvh; padding: 1rem; }
}
.confirm-card h3 { margin:0 0 .45rem; }
.confirm-card p { margin:0; color:var(--color-text-muted); }
.confirm-actions { display:flex; justify-content:flex-end; gap:.6rem; margin-top:1rem; }
</style>

@code {
    private List<Reminder> reminders = new();
    private AppUser? currentUser;
    private bool isLoading = true;
    private bool showForm = false;
    private Reminder? editingReminder;

    private bool showDeleteConfirm = false;
    private Reminder? pendingDeleteReminder;

    private int totalCount => reminders.Count;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = await UserManager.GetUserAsync(authState.User);
        if (currentUser != null)
        {
            reminders = await ReminderSvc.GetUserRemindersAsync(currentUser.Id);
        }
        isLoading = false;
    }

    void ShowNewForm() { editingReminder = null; showForm = true; }
    void HideForm() => showForm = false;

    void EditReminder(Reminder r) { editingReminder = r; showForm = true; }

    async Task OnReminderSaved()
    {
        showForm = false;
        if (currentUser != null) reminders = await ReminderSvc.GetUserRemindersAsync(currentUser.Id);
    }

    async Task PauseReminder(int id)
    {
        if (currentUser != null) await ReminderSvc.PauseAsync(id, currentUser.Id);
        reminders = reminders.Select(r => { if (r.Id == id) r.IsPaused = true; return r; }).ToList();
    }

    async Task ResumeReminder(int id)
    {
        if (currentUser != null) await ReminderSvc.ResumeAsync(id, currentUser.Id);
        reminders = reminders.Select(r => { if (r.Id == id) { r.IsPaused = false; r.IsActive = true; } return r; }).ToList();
    }

    Task DeleteReminder(int id)
    {
        pendingDeleteReminder = reminders.FirstOrDefault(r => r.Id == id);
        showDeleteConfirm = pendingDeleteReminder is not null;
        return Task.CompletedTask;
    }

    async Task ConfirmDelete()
    {
        if (pendingDeleteReminder is null || currentUser is null) return;

        await ReminderSvc.DeleteAsync(pendingDeleteReminder.Id, currentUser.Id);
        reminders = reminders.Where(r => r.Id != pendingDeleteReminder.Id).ToList();

        pendingDeleteReminder = null;
        showDeleteConfirm = false;
    }

    void CancelDelete()
    {
        pendingDeleteReminder = null;
        showDeleteConfirm = false;
    }
}
