@inject IReminderService ReminderSvc
@inject ISubscriptionService SubSvc

<div class="form-modal">
    <div class="form-modal-header">
        <h2>@(isEdit ? "Edit Reminder" : "New Reminder")</h2>
        <button class="btn-icon" @onclick="OnCancel">✕</button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">@errorMessage</div>
    }

    <EditForm Model="model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label>Name *</label>
            <InputText @bind-Value="model.Name" class="form-input" placeholder="e.g. Team standup" />
            <ValidationMessage For="() => model.Name" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <InputTextArea @bind-Value="model.Description" class="form-input form-textarea" placeholder="Optional description..." rows="2" />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Date &amp; Time *</label>
                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="model.OccursAt" class="form-input" />
                <ValidationMessage For="() => model.OccursAt" />
            </div>
            <div class="form-group">
                <label>Timezone</label>
                <InputSelect @bind-Value="model.TimeZoneId" class="form-input">
                    @foreach (var tz in CommonTimezones)
                    {
                        <option value="@tz.Id">@tz.DisplayName</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="form-group">
            <label>Recurring</label>
            <InputSelect @bind-Value="model.RecurringInterval" class="form-input">
                <option value="None">None (one-time)</option>
                <option value="Daily">Every day</option>
                <option value="Weekly">Every week (same day)</option>
                <option value="Monthly">Every month (same date)</option>
                <option value="Custom">Custom days of the week…</option>
            </InputSelect>
        </div>

        @if (model.RecurringInterval == "Custom")
        {
            <div class="form-group">
                <label>Repeat on</label>
                <div class="day-picker">
                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                    {
                        var isOn = model.CustomDays.Contains(day);
                        <button type="button"
                                class="day-btn @(isOn ? "active" : "")"
                                @onclick="() => ToggleDay(day)"
                                aria-pressed="@isOn">
                            @day.ToString()[..2]
                        </button>
                    }
                </div>
            </div>
        }

        <div class="form-group">
            <label>Notification Channels</label>
            <div class="channel-checkboxes">
                @foreach (var ch in Enum.GetValues<NotificationChannel>())
                {
                    var allowed = CurrentUser != null && SubSvc.IsChannelAllowed(CurrentUser, ch);
                    var isChecked = model.Channels.Contains(ch);
                    <label class="channel-pill @(isChecked ? "checked" : "") @(allowed ? "" : "locked")"
                           title="@(allowed ? "" : "Upgrade to Pro to unlock")"
                           aria-disabled="@(!allowed)">
                        <input type="checkbox"
                               checked="@isChecked"
                               disabled="@(!allowed)"
                               @onchange="(e) => ToggleChannel(ch, (bool)(e.Value ?? false))" />
                        <span class="pill-icon">@GetChannelEmoji(ch)</span>
                        <span class="pill-label">@ch</span>
                        @if (!allowed)
                        {
                            <span class="pro-badge">Pro</span>
                        }
                    </label>
                }
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @(isSaving ? "Saving..." : isEdit ? "Save Changes" : "Create Reminder")
            </button>
        </div>
    </EditForm>
</div>

<style>
    /* Modal header */
    .form-modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .form-modal-header h2 { font-size: 1.2rem; font-weight: 700; margin: 0; color: var(--color-text); }
    .btn-icon { font-size: 1rem; cursor: pointer; color: var(--color-text-muted); padding: 0.3rem 0.5rem; border-radius: 6px; transition: background 0.15s; }
    .btn-icon:hover { background: var(--color-primary-alpha); color: var(--color-primary); }

    /* Form row */
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-textarea { resize: vertical; min-height: 60px; }

    /* Channel pills */
    .channel-checkboxes { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    .channel-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0.875rem;
        border-radius: 10px;
        border: 1.5px solid var(--color-border);
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text);
        transition: border-color 0.15s, background 0.15s, color 0.15s;
        position: relative;
        user-select: none;
    }
    .channel-pill input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
    .channel-pill:hover:not(.locked) { border-color: var(--color-primary); background: var(--color-primary-alpha); }
    .channel-pill.checked { border-color: var(--color-primary); background: var(--color-primary-alpha); color: var(--color-primary); }
    .channel-pill.locked { opacity: 0.55; cursor: not-allowed; }
    .pill-icon { font-size: 1.1rem; }
    .pill-label { flex: 1; }

    .pro-badge { font-size: 0.65rem; font-weight: 700; background: var(--color-primary); color: #fff; padding: 2px 6px; border-radius: 20px; letter-spacing: 0.03em; text-transform: uppercase; margin-left: auto; }

    /* Day-of-week picker */
    .day-picker { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .day-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1.5px solid var(--color-border);
        background: transparent;
        color: var(--color-text);
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
    }
    .day-btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--color-primary-alpha); }
    .day-btn.active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

    /* Actions */
    .form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--color-border); }

    @@media (max-width: 600px) {
        .form-row { grid-template-columns: 1fr; }
        .channel-checkboxes { grid-template-columns: 1fr; }
    }
</style>

@code {
    [Parameter] public Reminder? Reminder { get; set; }
    [Parameter] public AppUser? CurrentUser { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ReminderFormModel model = new();
    private bool isEdit = false;
    private bool isSaving = false;
    private string? errorMessage;

    private static readonly (string Id, string DisplayName)[] CommonTimezones =
    [
        ("UTC", "UTC"),
        ("America/Los_Angeles", "Pacific Time (US)"),
        ("America/Denver", "Mountain Time (US)"),
        ("America/Chicago", "Central Time (US)"),
        ("America/New_York", "Eastern Time (US)"),
        ("Europe/London", "London"),
        ("Europe/Paris", "Paris / Berlin"),
        ("Asia/Tokyo", "Tokyo"),
        ("Asia/Shanghai", "Shanghai"),
        ("Australia/Sydney", "Sydney"),
    ];

    protected override void OnParametersSet()
    {
        if (Reminder != null)
        {
            isEdit = true;
            model = new ReminderFormModel
            {
                Name = Reminder.Name,
                Description = Reminder.Description,
                OccursAt = Reminder.OccursAt,
                TimeZoneId = Reminder.TimeZoneId,
                RecurringInterval = Reminder.RecurringInterval,
                Channels = Reminder.Channels.Select(c => c.Channel).ToHashSet()
            };
        }
        else
        {
            isEdit = false;
            model = new ReminderFormModel { OccursAt = DateTime.Now.AddHours(1) };
        }
    }

    void ToggleChannel(NotificationChannel ch, bool value)
    {
        if (value) model.Channels.Add(ch);
        else model.Channels.Remove(ch);
    }

    void ToggleDay(DayOfWeek day)
    {
        if (model.CustomDays.Contains(day)) model.CustomDays.Remove(day);
        else model.CustomDays.Add(day);
    }

    string GetChannelEmoji(NotificationChannel ch) => ch switch
    {
        NotificationChannel.Email => "📧",
        NotificationChannel.Push => "🔔",
        NotificationChannel.SMS => "📱",
        NotificationChannel.Voice => "📞",
        _ => "🔔"
    };

    async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            // Resolve the recurrence value — if Custom, encode the selected days
            var recurringValue = model.RecurringInterval == "Custom" && model.CustomDays.Any()
                ? "Custom:" + string.Join(",", model.CustomDays.OrderBy(d => (int)d).Select(d => d.ToString()))
                : model.RecurringInterval;

            if (isEdit && Reminder != null)
            {
                Reminder.Name = model.Name;
                Reminder.Description = model.Description;
                Reminder.OccursAt = model.OccursAt.ToUniversalTime();
                Reminder.TimeZoneId = model.TimeZoneId;
                Reminder.RecurringInterval = recurringValue;
                Reminder.Channels.Clear();
                foreach (var ch in model.Channels)
                    Reminder.Channels.Add(new ReminderChannel { Channel = ch });
                await ReminderSvc.UpdateAsync(Reminder);
            }
            else
            {
                var reminder = new Reminder
                {
                    UserId = CurrentUser!.Id,
                    Name = model.Name,
                    Description = model.Description,
                    OccursAt = model.OccursAt.ToUniversalTime(),
                    TimeZoneId = model.TimeZoneId,
                    RecurringInterval = recurringValue,
                    Channels = model.Channels.Select(ch => new ReminderChannel { Channel = ch }).ToList()
                };
                await ReminderSvc.CreateAsync(reminder);
            }
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private class ReminderFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = "";
        public string? Description { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public DateTime OccursAt { get; set; } = DateTime.Now.AddHours(1);
        public string TimeZoneId { get; set; } = "UTC";
        public string RecurringInterval { get; set; } = "None";
        public HashSet<NotificationChannel> Channels { get; set; } = new();
        public HashSet<DayOfWeek> CustomDays { get; set; } = new();
    }
}

