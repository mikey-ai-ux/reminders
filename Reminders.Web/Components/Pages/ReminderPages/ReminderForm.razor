@inject IReminderService ReminderSvc
@inject ISubscriptionService SubSvc
@inject IConfiguration Config
@inject IJSRuntime JS
@inject Reminders.Data.AppDbContext Db

<div class="form-modal">
    <div class="form-modal-header">
        <h2>@(isEdit ? "Edit Reminder" : "New Reminder")</h2>
        <button class="btn-icon" @onclick="OnCancel">✕</button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">@errorMessage</div>
    }

    <EditForm Model="model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label>Reminder type</label>
            <div class="type-row">
                <button type="button" class="type-btn @(model.ReminderType == "OneTime" ? "active" : "")" @onclick='() => model.ReminderType = "OneTime"'>One-time</button>
                <button type="button" class="type-btn @(model.ReminderType == "Recurring" ? "active" : "")" @onclick='() => model.ReminderType = "Recurring"'>Recurring</button>
            </div>
        </div>

        <div class="form-group">
            <label>Icon</label>
            <div class="icon-picker">
                @foreach (var icon in IconChoices)
                {
                    <button type="button" class="icon-btn @(model.Icon == icon ? "active" : "")" @onclick='() => model.Icon = icon'>@icon</button>
                }
            </div>
            <InputText @bind-Value="model.CustomIconUrl" class="form-input" placeholder="Optional custom icon URL (https://...)" />
            <ValidationMessage For="() => model.CustomIconUrl" />
        </div>

        <div class="form-group">
            <label>Name *</label>
            <InputText @bind-Value="model.Name" class="form-input" placeholder="e.g. Pay rent" />
            <ValidationMessage For="() => model.Name" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <InputTextArea @bind-Value="model.Description" class="form-input form-textarea" rows="2" />
        </div>

        @if (model.ReminderType == "OneTime")
        {
            <div class="form-row">
                <div class="form-group">
                    <label>Date *</label>
                    <InputDate @bind-Value="model.OneTimeDate" class="form-input" />
                </div>
                <div class="form-group">
                    <label>Time *</label>
                    <input type="time" class="form-input" value="@model.TimeOfDay" @onchange="OnTimeChanged" />
                </div>
            </div>
        }
        else
        {
            <div class="form-row">
                <div class="form-group">
                    <label>Time *</label>
                    <input type="time" class="form-input" value="@model.TimeOfDay" @onchange="OnTimeChanged" />
                </div>
                <div class="form-group">
                    <label>Recurring interval</label>
                    <InputSelect @bind-Value="model.RecurringInterval" class="form-input">
                        <option value="Daily">Daily</option>
                        <option value="Weekly">Weekly</option>
                        <option value="Monthly">Monthly</option>
                        <option value="Annually">Annually</option>
                        <option value="Custom">Custom days</option>
                    </InputSelect>
                </div>
            </div>

            @if (model.RecurringInterval == "Custom")
            {
                <div class="form-group">
                    <label>Repeat on</label>
                    <div class="day-picker">
                        @foreach (var day in Enum.GetValues<DayOfWeek>())
                        {
                            var isOn = model.CustomDays.Contains(day);
                            <button type="button" class="day-btn @(isOn ? "active" : "")" @onclick="() => ToggleDay(day)">@day.ToString()[..2]</button>
                        }
                    </div>
                </div>
            }
        }

        <div class="form-group">
            <label>Timezone</label>
            <InputSelect @bind-Value="model.TimeZoneId" class="form-input">
                @foreach (var tz in CommonTimezones)
                {
                    <option value="@tz.Id">@tz.DisplayName</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Notification channels</label>
            @if (!string.IsNullOrWhiteSpace(quotaWarning))
            {
                <div class="alert alert-info">@quotaWarning</div>
            }
            <div class="channel-checkboxes">
                @foreach (var ch in Enum.GetValues<NotificationChannel>())
                {
                    var allowed = CurrentUser != null && SubSvc.IsChannelAllowed(CurrentUser, ch);
                    var isChecked = model.Channels.Contains(ch);
                    <label class="channel-pill @(isChecked ? "checked" : "") @(allowed ? "" : "locked")">
                        <input type="checkbox" checked="@isChecked" disabled="@(!allowed)" @onchange="(e) => ToggleChannel(ch, (bool)(e.Value ?? false))" />
                        <span class="pill-icon">@GetChannelEmoji(ch)</span>
                        <span class="pill-label">@ch</span>
                        @if (!allowed)
                        {
                            <span class="pro-badge">Pro</span>
                        }
                    </label>
                }
            </div>

            @if (model.Channels.Contains(NotificationChannel.Push))
            {
                <div class="push-register-box">
                    <div class="push-text">
                        <strong>Push notifications require device registration.</strong>
                        <div>Open this website on each target device and register it once.</div>
                    </div>
                    <div class="push-actions">
                        <button type="button" class="btn btn-secondary" @onclick="RegisterCurrentDevice" disabled="@registeringDevice">@(registeringDevice ? "Registering..." : "Register current device")</button>
                        <button type="button" class="btn btn-ghost" @onclick="UnregisterCurrentDevice">Unregister device</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(pushDeviceStatus))
                    {
                        <div class="alert alert-info">@pushDeviceStatus</div>
                    }
                </div>
            }

            @if (model.Channels.Any())
            {
                <div class="target-picker">
                    <label>Delivery targets per channel</label>

                    @if (model.Channels.Contains(NotificationChannel.Push))
                    {
                        <div class="target-group">
                            <div class="target-title">Push devices</div>
                            @if (!availablePushTargets.Any())
                            {
                                <div class="muted">No push devices registered.</div>
                            }
                            else
                            {
                                @foreach (var t in availablePushTargets)
                                {
                                    var checkedVal = selectedPushTargets.Contains(t.Value);
                                    <label class="target-option"><input type="checkbox" checked="@checkedVal" @onchange="(e) => ToggleTarget(NotificationChannel.Push, t.Value, (bool)(e.Value ?? false))" /> @t.Label</label>
                                }
                            }
                        </div>
                    }

                    @if (model.Channels.Contains(NotificationChannel.Email))
                    {
                        <div class="target-group">
                            <div class="target-title">Email targets</div>
                            @if (!availableEmailTargets.Any())
                            {
                                <div class="muted">No confirmed email available.</div>
                            }
                            else
                            {
                                @foreach (var t in availableEmailTargets)
                                {
                                    var checkedVal = selectedEmailTargets.Contains(t.Value);
                                    <label class="target-option"><input type="checkbox" checked="@checkedVal" @onchange="(e) => ToggleTarget(NotificationChannel.Email, t.Value, (bool)(e.Value ?? false))" /> @t.Label</label>
                                }
                            }
                        </div>
                    }

                    @if (model.Channels.Contains(NotificationChannel.SMS) || model.Channels.Contains(NotificationChannel.Voice))
                    {
                        <div class="target-group">
                            <div class="target-title">Phone targets (SMS/Voice)</div>
                            @if (!availablePhoneTargets.Any())
                            {
                                <div class="muted">No confirmed phone available.</div>
                            }
                            else
                            {
                                @foreach (var t in availablePhoneTargets)
                                {
                                    var checkedVal = selectedPhoneTargets.Contains(t.Value);
                                    <label class="target-option"><input type="checkbox" checked="@checkedVal" @onchange="(e) => TogglePhoneTarget(t.Value, (bool)(e.Value ?? false))" /> @t.Label</label>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancel</button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">@(isSaving ? "Saving..." : isEdit ? "Save Changes" : "Create Reminder")</button>
        </div>
    </EditForm>
</div>

<style>
.form-modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; }
.form-row { display:grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
.type-row { display:flex; gap:.5rem; }
.type-btn { border:1px solid var(--color-border); border-radius:8px; padding:.45rem .8rem; }
.type-btn.active { background:var(--color-primary-alpha); color:var(--color-primary); border-color:var(--color-primary); }
.icon-picker { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:.5rem; }
.icon-btn { width:36px; height:36px; border:1px solid var(--color-border); border-radius:8px; }
.icon-btn.active { border-color:var(--color-primary); background:var(--color-primary-alpha); }
.day-picker { display:flex; gap:.4rem; flex-wrap:wrap; }
.day-btn { width:40px; height:40px; border-radius:50%; border:1px solid var(--color-border); }
.day-btn.active { background:var(--color-primary); color:#fff; border-color:var(--color-primary); }
.channel-checkboxes { display:grid; grid-template-columns:1fr 1fr; gap:.5rem; }
.channel-pill { display:flex; align-items:center; gap:.5rem; padding:.55rem .8rem; border:1px solid var(--color-border); border-radius:10px; }
.channel-pill.checked { border-color:var(--color-primary); background:var(--color-primary-alpha); }
.channel-pill.locked { opacity:.6; }
.channel-pill input { display:none; }
.pill-label { flex:1; }
.pro-badge { font-size:.65rem; background:var(--color-primary); color:#fff; padding:2px 6px; border-radius:12px; }
.push-register-box { margin-top:.75rem; border:1px dashed var(--color-border); border-radius:10px; padding:.75rem; background:var(--color-surface-2); }
.push-text { font-size:.82rem; color:var(--color-text-muted); margin-bottom:.5rem; }
.push-actions { display:flex; gap:.5rem; flex-wrap:wrap; }
.target-picker { margin-top:.75rem; border:1px solid var(--color-border); border-radius:10px; padding:.75rem; }
.target-group { margin-top:.6rem; }
.target-title { font-size:.82rem; font-weight:600; color:var(--color-text); margin-bottom:.25rem; }
.target-option { display:flex; align-items:center; gap:.45rem; font-size:.84rem; color:var(--color-text-muted); margin:.22rem 0; }
.form-actions { display:flex; justify-content:flex-end; gap:.5rem; margin-top:1rem; }
@@media (max-width: 640px) { .form-row,.channel-checkboxes { grid-template-columns:1fr; } }
</style>

@code {
    [Parameter] public Reminder? Reminder { get; set; }
    [Parameter] public AppUser? CurrentUser { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ReminderFormModel model = new();
    private bool isEdit;
    private bool isSaving;
    private string? errorMessage;
    private string? quotaWarning;
    private bool registeringDevice;
    private string? pushDeviceStatus;

    private readonly List<TargetOption> availablePushTargets = new();
    private readonly List<TargetOption> availableEmailTargets = new();
    private readonly List<TargetOption> availablePhoneTargets = new();

    private HashSet<string> selectedPushTargets = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> selectedEmailTargets = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> selectedPhoneTargets = new(StringComparer.OrdinalIgnoreCase);

    private static readonly string[] IconChoices = ["🔔","💊","🏠","💼","📅","💳","🚗","📞","🧾","🎯"];

    private static readonly (string Id, string DisplayName)[] CommonTimezones =
    [
        ("UTC", "UTC"),
        ("America/Los_Angeles", "Pacific Time (US)"),
        ("America/New_York", "Eastern Time (US)"),
        ("Europe/London", "London"),
        ("Europe/Paris", "Paris / Berlin"),
        ("Asia/Tokyo", "Tokyo")
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (Reminder is not null)
        {
            isEdit = true;
            model = new ReminderFormModel
            {
                Name = Reminder.Name,
                Description = Reminder.Description,
                OneTimeDate = Reminder.OccursAt.ToLocalTime().Date,
                TimeOfDay = Reminder.OccursAt.ToLocalTime().ToString("HH:mm"),
                TimeZoneId = Reminder.TimeZoneId,
                RecurringInterval = Reminder.RecurringInterval.StartsWith("Custom:") ? "Custom" : Reminder.RecurringInterval,
                ReminderType = Reminder.RecurringInterval == "None" ? "OneTime" : "Recurring",
                Channels = Reminder.Channels.Select(c => c.Channel).ToHashSet(),
                Icon = string.IsNullOrWhiteSpace(Reminder.Icon) ? "🔔" : Reminder.Icon,
                CustomIconUrl = Reminder.CustomIconUrl
            };

            if (Reminder.RecurringInterval.StartsWith("Custom:"))
            {
                var days = Reminder.RecurringInterval[7..].Split(',', StringSplitOptions.RemoveEmptyEntries);
                foreach (var d in days)
                    if (Enum.TryParse<DayOfWeek>(d, out var parsed)) model.CustomDays.Add(parsed);
            }
        }
        else
        {
            isEdit = false;
            model = new ReminderFormModel();
        }

        await LoadAvailableTargetsAsync();
        LoadSelectedTargetsFromReminder();
        await RefreshQuotaWarning();
    }

    private async Task LoadAvailableTargetsAsync()
    {
        availablePushTargets.Clear();
        availableEmailTargets.Clear();
        availablePhoneTargets.Clear();

        if (CurrentUser is null) return;

        var pushSubs = Db.PushSubscriptions
            .Where(x => x.UserId == CurrentUser.Id)
            .OrderByDescending(x => x.CreatedAt)
            .ToList();

        var idx = 1;
        foreach (var p in pushSubs)
        {
            var type = string.IsNullOrWhiteSpace(p.DeviceType) ? "Unknown Device" : p.DeviceType;
            var label = $"{type} #{idx}";
            availablePushTargets.Add(new TargetOption(p.Endpoint, label));
            idx++;
        }

        if (!string.IsNullOrWhiteSpace(CurrentUser.Email) && CurrentUser.EmailConfirmed)
            availableEmailTargets.Add(new TargetOption(CurrentUser.Email, $"Primary: {CurrentUser.Email}"));

        if (!string.IsNullOrWhiteSpace(CurrentUser.PhoneNumber) && CurrentUser.PhoneNumberConfirmed)
            availablePhoneTargets.Add(new TargetOption(CurrentUser.PhoneNumber, $"Primary: {CurrentUser.PhoneNumber}"));

        var contactEndpoints = Db.UserContactEndpoints
            .Where(x => x.UserId == CurrentUser.Id && x.IsConfirmed)
            .OrderByDescending(x => x.CreatedAt)
            .ToList();

        foreach (var ep in contactEndpoints)
        {
            if (ep.Channel == NotificationChannel.Email)
            {
                if (!availableEmailTargets.Any(x => string.Equals(x.Value, ep.Value, StringComparison.OrdinalIgnoreCase)))
                    availableEmailTargets.Add(new TargetOption(ep.Value, string.IsNullOrWhiteSpace(ep.Label) ? ep.Value : $"{ep.Label} ({ep.Value})"));
            }
            else if (ep.Channel == NotificationChannel.SMS || ep.Channel == NotificationChannel.Voice)
            {
                if (!availablePhoneTargets.Any(x => string.Equals(x.Value, ep.Value, StringComparison.OrdinalIgnoreCase)))
                    availablePhoneTargets.Add(new TargetOption(ep.Value, string.IsNullOrWhiteSpace(ep.Label) ? ep.Value : $"{ep.Label} ({ep.Value})"));
            }
        }
    }

    private void LoadSelectedTargetsFromReminder()
    {
        selectedPushTargets = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        selectedEmailTargets = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        selectedPhoneTargets = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (Reminder?.Targets == null) return;

        foreach (var t in Reminder.Targets)
        {
            switch (t.Channel)
            {
                case NotificationChannel.Push:
                    selectedPushTargets.Add(t.TargetValue);
                    break;
                case NotificationChannel.Email:
                    selectedEmailTargets.Add(t.TargetValue);
                    break;
                case NotificationChannel.SMS:
                case NotificationChannel.Voice:
                    selectedPhoneTargets.Add(t.TargetValue);
                    break;
            }
        }
    }

    private static string ShortValue(string value)
        => string.IsNullOrWhiteSpace(value) ? "(unknown)" : (value.Length > 42 ? value[..42] + "…" : value);

    private async Task RefreshQuotaWarning()
    {
        quotaWarning = null;
        if (CurrentUser is null) return;

        var info = await SubSvc.GetQuotaInfoAsync(CurrentUser);

        var warnings = new List<string>();
        if (model.Channels.Contains(NotificationChannel.SMS) && info.SmsLimitPerMonth > 0)
        {
            var left = info.SmsLimitPerMonth - info.SmsUsedThisMonth;
            if (left <= 0) warnings.Add($"SMS quota reached ({info.SmsUsedThisMonth}/{info.SmsLimitPerMonth})");
            else if (left <= 10) warnings.Add($"SMS quota almost reached ({info.SmsUsedThisMonth}/{info.SmsLimitPerMonth})");
        }

        if (model.Channels.Contains(NotificationChannel.Voice) && info.VoiceLimitPerMonth > 0)
        {
            var left = info.VoiceLimitPerMonth - info.VoiceUsedThisMonth;
            if (left <= 0) warnings.Add($"Voice call quota reached ({info.VoiceUsedThisMonth}/{info.VoiceLimitPerMonth})");
            else if (left <= 5) warnings.Add($"Voice quota almost reached ({info.VoiceUsedThisMonth}/{info.VoiceLimitPerMonth})");
        }

        if (warnings.Count > 0)
            quotaWarning = string.Join(" • ", warnings);
    }

    async Task ToggleChannel(NotificationChannel ch, bool value)
    {
        if (value) model.Channels.Add(ch); else model.Channels.Remove(ch);

        if (!value)
        {
            if (ch == NotificationChannel.Push) selectedPushTargets.Clear();
            if (ch == NotificationChannel.Email) selectedEmailTargets.Clear();
            if (ch == NotificationChannel.SMS || ch == NotificationChannel.Voice) selectedPhoneTargets.Clear();
        }

        await RefreshQuotaWarning();
    }

    void ToggleTarget(NotificationChannel ch, string value, bool selected)
    {
        var set = ch switch
        {
            NotificationChannel.Push => selectedPushTargets,
            NotificationChannel.Email => selectedEmailTargets,
            _ => selectedPhoneTargets
        };

        if (selected) set.Add(value); else set.Remove(value);
    }

    void TogglePhoneTarget(string value, bool selected)
    {
        if (selected) selectedPhoneTargets.Add(value); else selectedPhoneTargets.Remove(value);
    }

    void ToggleDay(DayOfWeek day)
    {
        if (model.CustomDays.Contains(day)) model.CustomDays.Remove(day); else model.CustomDays.Add(day);
    }

    void OnTimeChanged(ChangeEventArgs e)
    {
        model.TimeOfDay = e.Value?.ToString() ?? model.TimeOfDay;
    }

    private async Task RegisterCurrentDevice()
    {
        try
        {
            registeringDevice = true;
            pushDeviceStatus = null;

            var vapidPublic = Config["Vapid:PublicKey"];
            if (string.IsNullOrWhiteSpace(vapidPublic) || vapidPublic.Contains("YOUR_"))
            {
                pushDeviceStatus = "VAPID public key is not configured yet.";
                return;
            }

            var ok = await JS.InvokeAsync<bool>("registerPushSubscription", vapidPublic);
            pushDeviceStatus = ok
                ? "Current device registered for push successfully."
                : "Could not register this device. Please allow notifications and try again.";
        }
        catch (Exception ex)
        {
            pushDeviceStatus = $"Push registration failed: {ex.Message}";
        }
        finally
        {
            registeringDevice = false;
        }
    }

    private async Task UnregisterCurrentDevice()
    {
        try
        {
            await JS.InvokeVoidAsync("unregisterPushSubscription");
            pushDeviceStatus = "Current device unregistered from push.";
        }
        catch (Exception ex)
        {
            pushDeviceStatus = $"Unregister failed: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            isSaving = true;
            errorMessage = null;

            var localDate = model.ReminderType == "OneTime" ? model.OneTimeDate : DateTime.Today;
            if (!TimeOnly.TryParse(model.TimeOfDay, out var tod))
                tod = TimeOnly.FromDateTime(DateTime.Now.AddHours(1));

            if (!string.IsNullOrWhiteSpace(model.CustomIconUrl))
            {
                var ok = Uri.TryCreate(model.CustomIconUrl, UriKind.Absolute, out var uri)
                         && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
                if (!ok)
                    throw new InvalidOperationException("Custom icon URL must be a valid absolute http/https URL.");
            }

            var localDt = new DateTime(localDate.Year, localDate.Month, localDate.Day, tod.Hour, tod.Minute, 0, DateTimeKind.Local);
            var recurring = model.ReminderType == "OneTime" ? "None" : model.RecurringInterval;
            if (model.ReminderType == "Recurring" && model.RecurringInterval == "Custom" && model.CustomDays.Any())
                recurring = "Custom:" + string.Join(",", model.CustomDays.OrderBy(x => (int)x));

            if (isEdit && Reminder is not null)
            {
                Reminder.Name = model.Name;
                Reminder.Description = model.Description;
                Reminder.Icon = model.Icon;
                Reminder.CustomIconUrl = model.CustomIconUrl;
                Reminder.OccursAt = localDt.ToUniversalTime();
                Reminder.TimeZoneId = model.TimeZoneId;
                Reminder.RecurringInterval = recurring;
                Reminder.Channels.Clear();
                foreach (var ch in model.Channels) Reminder.Channels.Add(new ReminderChannel { Channel = ch });

                Reminder.Targets.Clear();
                foreach (var t in BuildTargets()) Reminder.Targets.Add(t);

                await ReminderSvc.UpdateAsync(Reminder);
            }
            else
            {
                var reminder = new Reminder
                {
                    UserId = CurrentUser!.Id,
                    Name = model.Name,
                    Description = model.Description,
                    Icon = model.Icon,
                    CustomIconUrl = model.CustomIconUrl,
                    OccursAt = localDt.ToUniversalTime(),
                    TimeZoneId = model.TimeZoneId,
                    RecurringInterval = recurring,
                    Channels = model.Channels.Select(ch => new ReminderChannel { Channel = ch }).ToList(),
                    Targets = BuildTargets()
                };
                await ReminderSvc.CreateAsync(reminder);
            }

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private List<ReminderTarget> BuildTargets()
    {
        var list = new List<ReminderTarget>();

        if (model.Channels.Contains(NotificationChannel.Push))
        {
            foreach (var val in selectedPushTargets)
            {
                var label = availablePushTargets.FirstOrDefault(x => string.Equals(x.Value, val, StringComparison.OrdinalIgnoreCase))?.Label
                            ?? "Push Device";
                list.Add(new ReminderTarget { Channel = NotificationChannel.Push, TargetType = "PushDevice", TargetValue = val, Label = label });
            }
        }

        if (model.Channels.Contains(NotificationChannel.Email))
        {
            foreach (var val in selectedEmailTargets)
                list.Add(new ReminderTarget { Channel = NotificationChannel.Email, TargetType = "EmailAddress", TargetValue = val, Label = val });
        }

        if (model.Channels.Contains(NotificationChannel.SMS))
        {
            foreach (var val in selectedPhoneTargets)
                list.Add(new ReminderTarget { Channel = NotificationChannel.SMS, TargetType = "PhoneNumber", TargetValue = val, Label = val });
        }

        if (model.Channels.Contains(NotificationChannel.Voice))
        {
            foreach (var val in selectedPhoneTargets)
                list.Add(new ReminderTarget { Channel = NotificationChannel.Voice, TargetType = "PhoneNumber", TargetValue = val, Label = val });
        }

        return list;
    }

    private static string GetChannelEmoji(NotificationChannel ch) => ch switch
    {
        NotificationChannel.Email => "📧",
        NotificationChannel.Push => "🔔",
        NotificationChannel.SMS => "📱",
        NotificationChannel.Voice => "📞",
        _ => "🔔"
    };

    private sealed record TargetOption(string Value, string Label);

    private sealed class ReminderFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string Icon { get; set; } = "🔔";
        [System.ComponentModel.DataAnnotations.Url(ErrorMessage = "Please provide a valid URL")]
        public string? CustomIconUrl { get; set; }

        public string ReminderType { get; set; } = "OneTime"; // OneTime | Recurring
        public DateTime OneTimeDate { get; set; } = DateTime.Today;
        public string TimeOfDay { get; set; } = DateTime.Now.AddHours(1).ToString("HH:mm");
        public string TimeZoneId { get; set; } = "UTC";
        public string RecurringInterval { get; set; } = "Daily";
        public HashSet<DayOfWeek> CustomDays { get; set; } = new();

        public HashSet<NotificationChannel> Channels { get; set; } =
            new([NotificationChannel.Email, NotificationChannel.Push]);
    }
}
