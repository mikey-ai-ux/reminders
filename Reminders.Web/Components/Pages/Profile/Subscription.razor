@page "/profile/subscription"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@inject ISubscriptionService SubSvc
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Subscription — Reminders</PageTitle>

<div class="tab-content card">
    <h2>Subscription Management</h2>

    <div class="current-plan">
        <div class="plan-info">
            <span class="tier-badge-lg tier-@(currentUser?.SubscriptionTier.ToString().ToLower())">
                @currentUser?.SubscriptionTier Plan
            </span>
            @if (currentUser?.SubscriptionExpiresAt != null)
            {
                <p class="expiry">Renews @currentUser.SubscriptionExpiresAt.Value.ToString("MMMM d, yyyy")</p>
            }
        </div>
    </div>

    <div class="plans-grid">
        @foreach (var p in plans)
        {
            <div class="plan-card @(p.Highlight ? "highlight" : "")">
                <h3>@p.Name</h3>
                <div class="price">$@p.Price<span>/month</span></div>
                <ul>
                    <li>Email + Push included</li>
                    <li>@p.SmsLimit SMS / month</li>
                    <li>@p.VoiceLimit voice calls / month</li>
                </ul>
                <button class="btn btn-primary" @onclick="() => Upgrade(p.Id)">Choose @p.Name</button>
            </div>
        }
    </div>

    @if (currentUser?.SubscriptionTier != Reminders.Models.Enums.SubscriptionTier.Free)
    {
        <div class="manage-sub">
            <button class="btn btn-secondary" @onclick="CancelSubscription">Cancel Subscription</button>
        </div>
    }
</div>

<style>
.current-plan { display: flex; align-items: center; margin-bottom: 1.5rem; }
.tier-badge-lg { font-size: 0.9rem; font-weight: 700; padding: 5px 14px; border-radius: 20px; }
.tier-free { background: var(--color-border); color: var(--color-text-muted); }
.tier-pro,.tier-business,.tier-enterprise { background: rgba(67,97,238,0.15); color: var(--color-primary); }
.expiry { color: var(--color-text-muted); font-size: 0.85rem; margin: 0.5rem 0 0; }
.plans-grid { display:grid; grid-template-columns: repeat(auto-fit,minmax(220px,1fr)); gap:1rem; }
.plan-card { border:1px solid var(--color-border); border-radius:12px; background:var(--color-surface); padding:1rem; }
.plan-card.highlight { border-color: var(--color-primary); box-shadow: 0 4px 18px rgba(67,97,238,.15); }
.plan-card h3 { margin:0 0 .5rem; }
.price { font-size:1.5rem; font-weight:800; margin-bottom:.6rem; }
.price span { font-size:.85rem; color:var(--color-text-muted); font-weight:400; }
.plan-card ul { margin:.3rem 0 1rem; padding-left:1rem; color:var(--color-text-muted); }
.manage-sub { margin-top:1rem; text-align:right; }
</style>

@code {
    private AppUser? currentUser;

    private readonly List<PlanOption> plans =
    [
        new() { Id = 2, Name = "Starter", Price = 9.99m, SmsLimit = 100, VoiceLimit = 10 },
        new() { Id = 3, Name = "Growth", Price = 29.99m, SmsLimit = 2000, VoiceLimit = 200, Highlight = true },
        new() { Id = 4, Name = "Scale", Price = 99.99m, SmsLimit = 10000, VoiceLimit = 1000 }
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = await UserManager.GetUserAsync(authState.User);
    }

    async Task Upgrade(int planId)
    {
        if (currentUser == null) return;
        var baseUrl = "https://localhost:5001";
        var url = await SubSvc.CreateCheckoutSessionAsync(currentUser, planId, $"{baseUrl}/profile/subscription?success=true", $"{baseUrl}/profile/subscription?cancelled=true");
        if (!string.IsNullOrEmpty(url))
        {
            // TODO: navigate to stripe url client-side
        }
    }

    void CancelSubscription()
    {
        // TODO: Call Stripe to cancel subscription
    }

    private sealed class PlanOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int SmsLimit { get; set; }
        public int VoiceLimit { get; set; }
        public bool Highlight { get; set; }
    }
}
