@page "/profile/payment-history"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Payment History — Reminders</PageTitle>

<div class="tab-content card">
    <h2>Payment History</h2>
    @if (payments.Count == 0)
    {
        <div class="empty-payments">
            <p>💳 No payments yet. Upgrade to Pro to unlock all features!</p>
            <a href="/profile/subscription" class="btn btn-primary">View Plans</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="payments-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.Date.ToString("MMM d, yyyy")</td>
                            <td>@p.Description</td>
                            <td>$@p.Amount.ToString("F2")</td>
                            <td><span class="status-pill status-@p.Status.ToLower()">@p.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
.tab-content.card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem; }
.tab-content h2 { font-size: 1.25rem; font-weight: 700; margin: 0 0 1.5rem; color: var(--color-text); }
.empty-payments { text-align: center; padding: 2rem; color: var(--color-text-muted); }
.empty-payments p { margin-bottom: 1rem; }
.table-wrap { overflow-x: auto; }
.payments-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
.payments-table th { text-align: left; padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border); color: var(--color-text-muted); font-weight: 600; }
.payments-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border); color: var(--color-text); }
.status-pill { font-size: 0.7rem; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
.status-paid { background: rgba(34,197,94,0.15); color: #22c55e; }
.status-pending { background: rgba(234,179,8,0.15); color: #eab308; }
.status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }
</style>

@code {
    private List<PaymentRecord> payments = new();

    // TODO: Load from Stripe API when real credentials provided
    // For now, show empty state
    private record PaymentRecord(DateTime Date, string Description, decimal Amount, string Status);
}
