@page "/profile"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Reminders.Data.AppDbContext Db
@rendermode InteractiveServer

<PageTitle>My Profile — Reminders</PageTitle>

@if (isLoading)
{
    <div class="card"><p>Loading profile…</p></div>
}
else if (currentUser is null)
{
    <div class="alert alert-error">Could not load your profile. Please sign in again.</div>
}
else
{
    <div class="profile-header">
        <div class="avatar">@GetInitial()</div>
        <div class="profile-info">
            <h1>@(currentUser.DisplayName ?? currentUser.Email ?? "User")</h1>
            <p class="profile-email">@currentUser.Email</p>
            <span class="tier-badge tier-@(currentUser.SubscriptionTier.ToString().ToLower())">@currentUser.SubscriptionTier Plan</span>
        </div>
    </div>

    <div class="profile-tabs">
        <button class="tab @(activeTab == "info" ? "active" : "")" @onclick='() => activeTab = "info"'>Registration Info</button>
        <button class="tab @(activeTab == "sub" ? "active" : "")" @onclick='() => activeTab = "sub"'>Subscription</button>
        <button class="tab @(activeTab == "history" ? "active" : "")" @onclick='() => activeTab = "history"'>Payment History</button>
    </div>

    @if (activeTab == "info")
    {
        <div class="tab-content card">
            <h2>Registration Info</h2>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            <EditForm Model="editModel" OnValidSubmit="SaveProfile" FormName="profile-edit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Name</label>
                    <InputText @bind-Value="editModel.DisplayName" class="form-input" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <InputText @bind-Value="editModel.Email" class="form-input" />
                    <div class="confirm-row">
                        <span class="badge @(currentUser.EmailConfirmed ? "badge-active" : "badge-paused")">
                            @(currentUser.EmailConfirmed ? "Email confirmed" : "Email not confirmed")
                        </span>
                        @if (!currentUser.EmailConfirmed)
                        {
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="GenerateEmailConfirmationLink">Generate confirmation link</button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(emailConfirmationLink))
                    {
                        <div class="confirm-help">
                            <input class="form-input" readonly value="@emailConfirmationLink" />
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="CopyEmailLink">Copy link</button>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label>Phone</label>
                    <InputText @bind-Value="editModel.PhoneNumber" class="form-input" placeholder="+1 555 123 4567" />
                    <div class="confirm-row">
                        <span class="badge @((currentUser.PhoneNumberConfirmed) ? "badge-active" : "badge-paused")">
                            @(currentUser.PhoneNumberConfirmed ? "Phone confirmed" : "Phone not confirmed")
                        </span>
                        @if (!currentUser.PhoneNumberConfirmed && !string.IsNullOrWhiteSpace(editModel.PhoneNumber))
                        {
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="GeneratePhoneCode">Send/Generate code</button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(phoneCodeHint))
                    {
                        <div class="confirm-help">
                            <span class="badge badge-info">Code (dev): @phoneCodeHint</span>
                        </div>
                    }
                    @if (!currentUser.PhoneNumberConfirmed)
                    {
                        <div class="confirm-help">
                            <InputText @bind-Value="phoneCodeInput" class="form-input" placeholder="Enter phone confirmation code" />
                            <button type="button" class="btn btn-sm btn-primary" @onclick="ConfirmPhoneCode">Confirm phone</button>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label>Timezone</label>
                    <InputSelect @bind-Value="editModel.TimeZoneId" class="form-input">
                        <option value="UTC">UTC</option>
                        <option value="America/Los_Angeles">Pacific Time</option>
                        <option value="America/New_York">Eastern Time</option>
                        <option value="Europe/London">London</option>
                        <option value="Europe/Paris">Paris</option>
                        <option value="Asia/Tokyo">Tokyo</option>
                    </InputSelect>
                </div>

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </EditForm>

            <div class="cal-subscribe card-section">
                <h3>📅 Mobile Calendar Sync</h3>
                <p class="muted">Subscribe in iOS/Android calendar and get native mobile notifications.</p>

                <div class="cal-url-box">
                    <input type="text" readonly value="@CalendarUrl" class="cal-url-input" />
                    <button class="btn btn-secondary" @onclick="CopyCalendarUrl">@(copied ? "✅ Copied!" : "📋 Copy Link")</button>
                </div>
            </div>

            <div class="device-list card-section">
                <h3>📱 Registered Push Devices</h3>
                @if (!pushDevices.Any())
                {
                    <p class="muted">No devices registered yet.</p>
                }
                else
                {
                    <ul class="devices">
                        @foreach (var d in pushDevices)
                        {
                            <li>
                                <div class="dev-main">
                                    <code>@ShortEndpoint(d.Endpoint)</code>
                                    <span class="muted">@d.DeviceType • Added @d.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                </div>
                                <button type="button" class="btn btn-sm btn-danger-ghost" @onclick="() => RemoveDevice(d.Id)">Remove</button>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="device-list card-section">
                <h3>📮 Additional Email/Phone Endpoints</h3>
                <p class="muted">Add and confirm extra endpoints that can be selected per reminder.</p>

                <div class="confirm-help">
                    <select class="form-input" @bind="newEndpointChannel">
                        <option value="Email">Email</option>
                        <option value="SMS">Phone (SMS/Voice)</option>
                    </select>
                    <InputText class="form-input" @bind-Value="newEndpointValue" placeholder="email@example.com or +123..." />
                    <InputText class="form-input" @bind-Value="newEndpointLabel" placeholder="Label (Work, Personal, etc.)" />
                    <button type="button" class="btn btn-sm btn-primary" @onclick="AddEndpoint">Add endpoint</button>
                </div>

                @if (!contactEndpoints.Any())
                {
                    <p class="muted">No additional endpoints yet.</p>
                }
                else
                {
                    <ul class="devices">
                        @foreach (var ep in contactEndpoints)
                        {
                            <li>
                                <div class="dev-main">
                                    <code>@ep.Value</code>
                                    <span class="muted">@ep.Channel • @(string.IsNullOrWhiteSpace(ep.Label) ? "No label" : ep.Label) • @(ep.IsConfirmed ? "Confirmed" : "Unconfirmed")</span>
                                </div>
                                <div class="confirm-help">
                                    @if (!ep.IsConfirmed)
                                    {
                                        if (ep.Channel == Reminders.Models.Enums.NotificationChannel.Email)
                                        {
                                            <button type="button" class="btn btn-sm btn-secondary" @onclick="() => GenerateEndpointEmailLink(ep.Id)">Generate link</button>
                                            @if (endpointEmailLinks.TryGetValue(ep.Id, out var link) && !string.IsNullOrWhiteSpace(link))
                                            {
                                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => CopyText(link)">Copy link</button>
                                            }
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-secondary" @onclick="() => GenerateEndpointPhoneCode(ep.Id)">Generate code</button>
                                            <input class="form-input" value="@GetEndpointPhoneCode(ep.Id)" @onchange="(e) => SetEndpointPhoneCode(ep.Id, e.Value?.ToString())" placeholder="Code" />
                                            <button type="button" class="btn btn-sm btn-primary" @onclick="() => ConfirmEndpointPhoneCode(ep.Id)">Confirm</button>
                                        }
                                    }
                                    <button type="button" class="btn btn-sm btn-danger-ghost" @onclick="() => RemoveEndpoint(ep.Id)">Remove</button>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
    else if (activeTab == "sub")
    {
        <Subscription />
    }
    else
    {
        <PaymentHistory />
    }
}

<style>
.profile-header { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; padding: 1.5rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; }
.avatar { width: 64px; height: 64px; background: var(--color-primary); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; font-weight: 700; }
.profile-info h1 { margin: 0 0 0.2rem; }
.profile-email { margin: 0 0 0.4rem; color: var(--color-text-muted); }
.profile-tabs { display: flex; gap: .25rem; margin-bottom: 1rem; border-bottom: 1px solid var(--color-border); }
.tab { padding: .75rem 1rem; border-bottom: 2px solid transparent; color: var(--color-text-muted); }
.tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); font-weight: 600; }
.tab-content.card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; }
.confirm-row { margin-top: .45rem; display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; }
.confirm-help { margin-top: .5rem; display:flex; gap:.5rem; align-items:center; flex-wrap:wrap; }
.cal-subscribe { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-border); }
.cal-url-box { display: flex; gap: .5rem; margin-top: .75rem; }
.cal-url-input { flex: 1; font-size: .8rem; padding: .5rem .75rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-bg); color: var(--color-text-muted); font-family: monospace; }
.device-list { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--color-border); }
.devices { list-style: none; padding: 0; margin: .5rem 0 0; display: flex; flex-direction: column; gap: .5rem; }
.devices li { display: flex; justify-content: space-between; align-items: center; gap: .75rem; border: 1px solid var(--color-border); border-radius: 10px; padding: .6rem .7rem; background: var(--color-bg); }
.dev-main { display: flex; flex-direction: column; gap: .2rem; min-width: 0; }
.dev-main code { font-size: .75rem; overflow-wrap: anywhere; }
</style>

@code {
    private AppUser? currentUser;
    private bool isLoading = true;
    private string activeTab = "info";
    private string? successMessage;
    private bool copied;
    private string? emailConfirmationLink;
    private string? phoneCodeHint;
    private string phoneCodeInput = string.Empty;
    private List<PushSubscriptionRecord> pushDevices = new();
    private List<UserContactEndpoint> contactEndpoints = new();

    private string newEndpointChannel = "Email";
    private string newEndpointValue = string.Empty;
    private string newEndpointLabel = string.Empty;
    private Dictionary<int, string> endpointEmailLinks = new();
    private Dictionary<int, string> endpointPhoneCodes = new();

    private EditProfileModel editModel = new();
    private string CalendarUrl => $"{Nav.BaseUri}api/calendar/{currentUser?.Id}/reminders.ics";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = await UserManager.GetUserAsync(authState.User);

        if (currentUser is not null)
        {
            editModel.DisplayName = currentUser.DisplayName ?? string.Empty;
            editModel.Email = currentUser.Email ?? string.Empty;
            editModel.PhoneNumber = currentUser.PhoneNumber ?? string.Empty;
            editModel.TimeZoneId = string.IsNullOrWhiteSpace(currentUser.TimeZoneId) ? "UTC" : currentUser.TimeZoneId;

            pushDevices = Db.PushSubscriptions
                .Where(x => x.UserId == currentUser.Id)
                .OrderByDescending(x => x.CreatedAt)
                .ToList();

            contactEndpoints = Db.UserContactEndpoints
                .Where(x => x.UserId == currentUser.Id)
                .OrderByDescending(x => x.CreatedAt)
                .ToList();
        }

        isLoading = false;
    }

    private string GetInitial() => (currentUser?.DisplayName ?? currentUser?.Email ?? "?").FirstOrDefault().ToString().ToUpperInvariant();

    private async Task CopyCalendarUrl()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", CalendarUrl);
        copied = true;
        await Task.Delay(1500);
        copied = false;
    }

    private async Task GenerateEmailConfirmationLink()
    {
        if (currentUser is null || string.IsNullOrWhiteSpace(currentUser.Email)) return;

        var token = await UserManager.GenerateEmailConfirmationTokenAsync(currentUser);
        var encoded = Uri.EscapeDataString(token);
        emailConfirmationLink = $"{Nav.BaseUri}confirm-email?userId={Uri.EscapeDataString(currentUser.Id)}&code={encoded}";
    }

    private async Task CopyEmailLink()
    {
        if (!string.IsNullOrWhiteSpace(emailConfirmationLink))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", emailConfirmationLink);
    }

    private async Task GeneratePhoneCode()
    {
        if (currentUser is null || string.IsNullOrWhiteSpace(editModel.PhoneNumber)) return;
        phoneCodeHint = await UserManager.GenerateChangePhoneNumberTokenAsync(currentUser, editModel.PhoneNumber);
    }

    private async Task ConfirmPhoneCode()
    {
        if (currentUser is null || string.IsNullOrWhiteSpace(editModel.PhoneNumber) || string.IsNullOrWhiteSpace(phoneCodeInput)) return;

        var ok = await UserManager.VerifyChangePhoneNumberTokenAsync(currentUser, phoneCodeInput, editModel.PhoneNumber);
        if (!ok)
        {
            successMessage = "Invalid phone code.";
            return;
        }

        var result = await UserManager.ChangePhoneNumberAsync(currentUser, editModel.PhoneNumber, phoneCodeInput);
        successMessage = result.Succeeded ? "Phone confirmed successfully." : string.Join("; ", result.Errors.Select(e => e.Description));
    }

    private string ShortEndpoint(string endpoint)
    {
        if (string.IsNullOrWhiteSpace(endpoint)) return "(unknown)";
        return endpoint.Length > 80 ? endpoint[..80] + "…" : endpoint;
    }

    private async Task RemoveDevice(int id)
    {
        var sub = Db.PushSubscriptions.FirstOrDefault(x => x.Id == id && currentUser != null && x.UserId == currentUser.Id);
        if (sub == null) return;

        Db.PushSubscriptions.Remove(sub);
        await Db.SaveChangesAsync();

        pushDevices = pushDevices.Where(x => x.Id != id).ToList();
    }

    private async Task AddEndpoint()
    {
        if (currentUser is null) return;
        if (string.IsNullOrWhiteSpace(newEndpointValue)) return;

        var channel = newEndpointChannel == "Email" ? Reminders.Models.Enums.NotificationChannel.Email : Reminders.Models.Enums.NotificationChannel.SMS;
        var value = newEndpointValue.Trim();

        if (channel == Reminders.Models.Enums.NotificationChannel.Email)
        {
            if (!new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(value))
            {
                successMessage = "Invalid email format.";
                return;
            }
        }
        else
        {
            // Basic E.164-like validation
            if (!System.Text.RegularExpressions.Regex.IsMatch(value, "^\\+?[1-9]\\d{7,14}$"))
            {
                successMessage = "Invalid phone format. Use international format like +123456789.";
                return;
            }
        }

        var exists = Db.UserContactEndpoints.Any(x => x.UserId == currentUser.Id && x.Channel == channel && x.Value == value);
        if (exists)
        {
            successMessage = "Endpoint already exists.";
            return;
        }

        var ep = new UserContactEndpoint
        {
            UserId = currentUser.Id,
            Channel = channel,
            Value = value,
            Label = string.IsNullOrWhiteSpace(newEndpointLabel) ? null : newEndpointLabel.Trim(),
            IsConfirmed = false,
            VerificationToken = Guid.NewGuid().ToString("N"),
            VerificationCode = Random.Shared.Next(100000, 999999).ToString(),
            VerificationExpiresAtUtc = DateTime.UtcNow.AddMinutes(30),
            CreatedAt = DateTime.UtcNow
        };

        Db.UserContactEndpoints.Add(ep);
        await Db.SaveChangesAsync();

        contactEndpoints.Insert(0, ep);
        newEndpointValue = string.Empty;
        newEndpointLabel = string.Empty;
        successMessage = "Endpoint added. Please confirm it before using it in reminders.";
    }

    private async Task GenerateEndpointEmailLink(int id)
    {
        var ep = Db.UserContactEndpoints.FirstOrDefault(x => x.Id == id && currentUser != null && x.UserId == currentUser.Id && x.Channel == Reminders.Models.Enums.NotificationChannel.Email);
        if (ep == null) return;

        ep.VerificationToken = Guid.NewGuid().ToString("N");
        ep.VerificationExpiresAtUtc = DateTime.UtcNow.AddMinutes(30);
        await Db.SaveChangesAsync();

        endpointEmailLinks[id] = $"{Nav.BaseUri}confirm-contact-endpoint?endpointId={id}&token={ep.VerificationToken}";
    }

    private async Task GenerateEndpointPhoneCode(int id)
    {
        var ep = Db.UserContactEndpoints.FirstOrDefault(x => x.Id == id && currentUser != null && x.UserId == currentUser.Id && x.Channel == Reminders.Models.Enums.NotificationChannel.SMS);
        if (ep == null) return;

        ep.VerificationCode = Random.Shared.Next(100000, 999999).ToString();
        ep.VerificationExpiresAtUtc = DateTime.UtcNow.AddMinutes(30);
        await Db.SaveChangesAsync();

        successMessage = $"Phone verification code (dev): {ep.VerificationCode}";
    }

    private async Task ConfirmEndpointPhoneCode(int id)
    {
        var ep = Db.UserContactEndpoints.FirstOrDefault(x => x.Id == id && currentUser != null && x.UserId == currentUser.Id && x.Channel == Reminders.Models.Enums.NotificationChannel.SMS);
        if (ep == null) return;

        endpointPhoneCodes.TryGetValue(id, out var input);
        if (string.IsNullOrWhiteSpace(input) || string.IsNullOrWhiteSpace(ep.VerificationCode) || !string.Equals(input.Trim(), ep.VerificationCode, StringComparison.OrdinalIgnoreCase) || (ep.VerificationExpiresAtUtc.HasValue && ep.VerificationExpiresAtUtc.Value < DateTime.UtcNow))
        {
            successMessage = "Invalid or expired phone verification code.";
            return;
        }

        ep.IsConfirmed = true;
        ep.VerificationCode = null;
        ep.VerificationExpiresAtUtc = null;
        await Db.SaveChangesAsync();

        var inList = contactEndpoints.FirstOrDefault(x => x.Id == id);
        if (inList != null) inList.IsConfirmed = true;
        endpointPhoneCodes[id] = string.Empty;
    }

    private async Task CopyText(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
    }

    private string GetEndpointPhoneCode(int id)
        => endpointPhoneCodes.TryGetValue(id, out var code) ? code : string.Empty;

    private void SetEndpointPhoneCode(int id, string? code)
        => endpointPhoneCodes[id] = code ?? string.Empty;

    private async Task RemoveEndpoint(int id)
    {
        var ep = Db.UserContactEndpoints.FirstOrDefault(x => x.Id == id && currentUser != null && x.UserId == currentUser.Id);
        if (ep == null) return;

        Db.UserContactEndpoints.Remove(ep);
        await Db.SaveChangesAsync();

        contactEndpoints = contactEndpoints.Where(x => x.Id != id).ToList();
    }

    private async Task SaveProfile()
    {
        if (currentUser is null) return;

        currentUser.DisplayName = editModel.DisplayName?.Trim();
        currentUser.TimeZoneId = editModel.TimeZoneId;

        if (!string.Equals(currentUser.Email, editModel.Email, StringComparison.OrdinalIgnoreCase))
        {
            currentUser.Email = editModel.Email?.Trim();
            currentUser.UserName = editModel.Email?.Trim();
            currentUser.EmailConfirmed = false; // requires confirmation again
        }

        if (!string.Equals(currentUser.PhoneNumber, editModel.PhoneNumber, StringComparison.OrdinalIgnoreCase))
        {
            currentUser.PhoneNumber = editModel.PhoneNumber?.Trim();
            currentUser.PhoneNumberConfirmed = false; // requires confirmation again
        }

        var result = await UserManager.UpdateAsync(currentUser);
        successMessage = result.Succeeded
            ? "Profile saved. If you changed email/phone, confirmation is required before full use."
            : string.Join("; ", result.Errors.Select(e => e.Description));
    }

    private sealed class EditProfileModel
    {
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string TimeZoneId { get; set; } = "UTC";
    }
}
