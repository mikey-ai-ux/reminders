<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reminders</title>
    <base href="/" />

    <script>
        (function () {
            function getCookie(name) {
                var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                return match ? decodeURIComponent(match[2]) : null;
            }

            function setCookie(name, value) {
                document.cookie = name + '=' + encodeURIComponent(value) + '; path=/; max-age=31536000; SameSite=Lax';
            }

            var initial = 'light';
            try {
                var stored = localStorage.getItem('theme');
                var cookieTheme = getCookie('theme');
                initial = stored || cookieTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                localStorage.setItem('theme', initial);
                setCookie('theme', initial);
            } catch {
                var cookieOnly = getCookie('theme');
                initial = cookieOnly || 'light';
                setCookie('theme', initial);
            }

            document.documentElement.setAttribute('data-theme', initial);
        })();
    </script>

    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="Reminders.Web.styles.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="js/theme.js"></script>
    <script src="js/push.js"></script>
</body>

</html>
