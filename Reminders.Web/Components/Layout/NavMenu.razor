@rendermode InteractiveServer

<nav class="navbar">
    <div class="navbar-brand">
        <a href="/" class="brand-link">📨 Reminders</a>
    </div>

    <button class="nav-toggle" @onclick="ToggleMenu" aria-label="Toggle navigation" aria-expanded="@menuOpen">
        <span></span><span></span><span></span>
    </button>

    <ul class="nav-links @(menuOpen ? "open" : "")" @onclick="CloseMenu">
        <li><NavLink href="/" Match="NavLinkMatch.All" class="nav-link">Home</NavLink></li>

        <AuthorizeView>
            <Authorized>
                <li><NavLink href="/reminders" class="nav-link">Reminders</NavLink></li>
                <li><NavLink href="/history" class="nav-link">History</NavLink></li>
                <li><NavLink href="/profile" class="nav-link">My Profile</NavLink></li>
                <li><NavLink href="/profile/subscription" class="nav-link">Subscription</NavLink></li>
                <li><NavLink href="/profile/payment-history" class="nav-link">Payments</NavLink></li>
                <li>
                    <form method="post" action="/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link btn-link">Logout</button>
                    </form>
                </li>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login" class="nav-link btn-auth-login">Login</NavLink></li>
                <li><NavLink href="/register" class="nav-link btn-primary-nav btn-auth-signup">Sign Up</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>

        <li>
            <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">🌙</button>
        </li>
    </ul>
</nav>

@code {
    private bool menuOpen;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;
}
