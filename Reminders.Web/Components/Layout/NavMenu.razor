@inject NavigationManager Navigation
<AuthorizeView>
    <Authorized Context="authState">
        @{ var user = authState.User; }
    </Authorized>
</AuthorizeView>

<nav class="navbar">
    <div class="navbar-brand">
        <a href="/" class="brand-link">🔔 Reminders</a>
    </div>
    <button class="nav-toggle" @onclick="ToggleMenu" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
    </button>
    <ul class="nav-links @(menuOpen ? "open" : "")">
        <li><NavLink href="/" Match="NavLinkMatch.All" class="nav-link">🏠 Home</NavLink></li>
        <AuthorizeView>
            <Authorized>
                <li><NavLink href="/reminders" class="nav-link">🔔 Reminders</NavLink></li>
                <li class="nav-dropdown">
                    <button class="nav-link nav-dropdown-toggle" @onclick="ToggleProfile">👤 My Profile ▾</button>
                    @if (profileOpen)
                    {
                        <ul class="dropdown-menu">
                            <li><NavLink href="/profile" class="dropdown-item">Profile</NavLink></li>
                            <li><NavLink href="/profile/subscription" class="dropdown-item">Subscription</NavLink></li>
                            <li><NavLink href="/profile/payment-history" class="dropdown-item">Payment History</NavLink></li>
                        </ul>
                    }
                </li>
                <li>
                    <form method="post" action="/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link btn-link">Logout</button>
                    </form>
                </li>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login" class="nav-link">Login</NavLink></li>
                <li><NavLink href="/register" class="nav-link btn-primary-nav">Sign Up</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>
        <li>
            <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">🌙</button>
        </li>
    </ul>
</nav>

@code {
    private bool menuOpen = false;
    private bool profileOpen = false;

    void ToggleMenu() => menuOpen = !menuOpen;
    void ToggleProfile() => profileOpen = !profileOpen;
}
